# ──────────────────────────────────────────────────────────────────
# OPTION-SELLING CONFIG — ₹7 Lakh starting capital
# Reference template only. Not loaded by any engine yet.
# Copy to .env and rename keys to wire into code when ready.
# ──────────────────────────────────────────────────────────────────

# === CAPITAL BUCKETS ===
SELL_TOTAL_CAPITAL=700000
SELL_ACTIVE_CAPITAL=400000
SELL_RESERVE=200000
SELL_TAIL_BUFFER=80000
SELL_CASH_FLOAT=20000

# === STRATEGY: NIFTY weekly credit spreads ===
SELL_STRUCTURE=credit_spread
SELL_INSTRUMENT=NIFTY
SELL_SHORT_DELTA=0.15
SELL_HEDGE_WIDTH=200
SELL_DTE_MIN=2
SELL_DTE_MAX=5

# === POSITION SIZING ===
SELL_MARGIN_PER_SPREAD=20000
SELL_MAX_CONCURRENT=8
SELL_MARGIN_UTILIZATION_MAX=0.40

# === EXIT RULES ===
SELL_PROFIT_TAKE_PCT=50
SELL_STOP_LOSS_MULT=2.0
SELL_DTE_FORCE_CLOSE=1

# === COMPOUNDING (half-compound) ===
SELL_PROFIT_REINVEST_PCT=0.50

# === HALT TRIGGERS ===
SELL_PAUSE_ACTIVE_BELOW=300000
SELL_HALT_ACTIVE_BELOW=200000
SELL_KILL_RESERVE_BELOW=100000
SELL_MAX_CONSEC_LOSSES=4
SELL_MAX_DAILY_LOSS_PCT=3

# === REQUIRED BEFORE ENABLING ===
SELL_AUTO_ENABLED=false
SELL_PAPER_VALIDATED=false
SELL_BACKTEST_WIN_RATE_VALIDATED=false
