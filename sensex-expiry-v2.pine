// ═══════════════════════════════════════════════════════════════════
// SENSEX EXPIRY DAY — OPTIMIZED OPTIONS STRATEGY  v2
// ═══════════════════════════════════════════════════════════════════
// Chart  : BSE:SENSEX  — Daily timeframe ONLY
//
// KEY FINDINGS from 1200-week backtest optimizer:
//   ALL_ATM + NO_MEDIUM  → 78.18% win rate  (vs 54.4% baseline)
//   VOLEXP + EMA + NOMED → 69.8% win rate, fewer but higher quality
//
// RULES (matching JS backtest exactly):
//   1. Only trade EVENT and HIGH confidence signals (drop MEDIUM/TREND)
//   2. Always buy ATM options (not OTM) — delta ≈ 0.5 → higher win prob
//   3. HIGH signals (POWER_TREND,GAP_CONT): SL=29.75%, trail@1.95x, lock60%
//   4. EVENT signals:                        SL=35%,    trail@1.5x,  lock50%
//   5. Optional: Vol Expansion / EMA10 filters
//
// Paste into TradingView Pine Editor on BSE:SENSEX Daily chart
// ═══════════════════════════════════════════════════════════════════

//@version=5
indicator("SENSEX Expiry v2 [Optimised]", overlay=true, max_labels_count=500)

// ── PRESET MODES ──────────────────────────────────────────────────
i_mode = input.string("HIGH_WIN", "Strategy Mode",
  options=["HIGH_WIN","BALANCED","AGGRESSIVE","CUSTOM"],
  tooltip="HIGH_WIN=78.18% win (ATM+NoMedium, SL/trail auto-adjusted per signal) | BALANCED=65% win | AGGRESSIVE=54% (baseline+OTM) | CUSTOM=use your own inputs")

// ── CUSTOM INPUTS (only used in CUSTOM mode) ──────────────────────
grpSig = "Signal Filters (CUSTOM mode only)"
i_powerBody  = input.float(0.75, "POWER_TREND min body ratio",  minval=0.5, maxval=1.0, step=0.01, group=grpSig)
i_powerRange = input.float(1.2,  "POWER_TREND min range %",     minval=0.5, maxval=3.0, step=0.1,  group=grpSig)
i_gapBody    = input.float(0.60, "GAP_CONT min body ratio",     minval=0.5, maxval=1.0, step=0.01, group=grpSig)
i_gapRange   = input.float(1.0,  "GAP_CONT min range %",        minval=0.5, maxval=3.0, step=0.1,  group=grpSig)
i_noMedium   = input.bool(true,  "Drop MEDIUM signals (TREND+GAP_REV)", group=grpSig)
i_useEMA     = input.bool(false, "EMA10 trend alignment filter", group=grpSig)
i_useVolExp  = input.bool(false, "Vol Expansion filter (HV rising)", group=grpSig)
i_streakMin  = input.int(0,      "Min prior-day streak (0=off)", minval=0, maxval=3, group=grpSig)
i_minHV      = input.float(12,   "Min HV% to trade",             minval=5, maxval=25, group=grpSig)

grpRisk = "Risk (all modes)"
i_slPct     = input.float(35,   "Stop Loss % (base)",            minval=10, maxval=60, group=grpRisk,
              tooltip="HIGH signals auto-use 85% of this (e.g. 35%→29.75%). EVENT uses full value.")
i_trail1x   = input.float(1.5,  "Trail trigger (× entry, base)", minval=1.2, maxval=5.0, step=0.1, group=grpRisk,
              tooltip="HIGH signals auto-multiply by 1.3× (e.g. 1.5→1.95x). EVENT uses base value.")
i_trail1lk  = input.float(50,   "Trail lock % (base)",           minval=30, maxval=80, group=grpRisk,
              tooltip="HIGH signals auto-add 10% (e.g. 50→60%). EVENT uses base value.")

grpStrike = "Strike Selection (all modes)"
i_highStrike  = input.int(0, "HIGH signal strike offset (0=ATM,1=OTM+1)", minval=0, maxval=2, group=grpStrike)
i_eventStrike = input.int(1, "EVENT strike offset",                        minval=0, maxval=3, group=grpStrike)

grpDisp = "Display"
i_showStats = input.bool(true,  "Show stats table",    group=grpDisp)
i_showChain = input.bool(true,  "Show option chain",   group=grpDisp)
i_showLabel = input.bool(true,  "Show trade labels",   group=grpDisp)
i_showEMA   = input.bool(false, "Plot EMA10",          group=grpDisp)

// ── RESOLVE MODE PARAMS ───────────────────────────────────────────
// Each mode overrides the signal filter parameters
float powerBody  = i_mode == "CUSTOM" ? i_powerBody  : i_mode == "HIGH_WIN" ? 0.75 : i_mode == "BALANCED" ? 0.78 : 0.75
float powerRange = i_mode == "CUSTOM" ? i_powerRange : i_mode == "HIGH_WIN" ? 1.2  : i_mode == "BALANCED" ? 1.3  : 1.2
float gapBody    = i_mode == "CUSTOM" ? i_gapBody    : i_mode == "HIGH_WIN" ? 0.60 : i_mode == "BALANCED" ? 0.65 : 0.60
float gapRange   = i_mode == "CUSTOM" ? i_gapRange   : i_mode == "HIGH_WIN" ? 1.0  : i_mode == "BALANCED" ? 1.1  : 1.0
bool  noMedium   = i_mode == "CUSTOM" ? i_noMedium   : i_mode != "AGGRESSIVE"
bool  useEMA     = i_mode == "CUSTOM" ? i_useEMA     : i_mode == "BALANCED"
bool  useVolExp  = i_mode == "CUSTOM" ? i_useVolExp  : i_mode == "BALANCED"
int   streakMin  = i_mode == "CUSTOM" ? i_streakMin  : 0
float minHVpct   = i_mode == "CUSTOM" ? i_minHV      : 12
int   highStrike = i_mode == "CUSTOM" ? i_highStrike : i_mode == "AGGRESSIVE" ? 1 : 0
int   eventStk   = i_mode == "CUSTOM" ? i_eventStrike : i_mode == "HIGH_WIN" ? 1 : i_mode == "BALANCED" ? 1 : 2

// ── BLACK-SCHOLES ─────────────────────────────────────────────────
normCDF(x) =>
    a1=0.254829592, a2=-0.284496736, a3=1.421413741, a4=-1.453152027, a5=1.061405429
    p=0.3275911
    s = x < 0 ? -1.0 : 1.0
    ax = math.abs(x)
    t  = 1.0 / (1.0 + p * ax)
    y  = 1.0 - (((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*math.exp(-ax*ax)
    0.5 * (1.0 + s * y)

bsPrice(S, K, T, r, sigma, isCall) =>
    float result = 0.0
    if T <= 0.000001
        result := isCall ? math.max(S - K, 0.0) : math.max(K - S, 0.0)
    else
        d1 = (math.log(S / K) + (r + 0.5*sigma*sigma)*T) / (sigma * math.sqrt(T))
        d2 = d1 - sigma * math.sqrt(T)
        result := isCall
          ? S*normCDF(d1) - K*math.exp(-r*T)*normCDF(d2)
          : K*math.exp(-r*T)*normCDF(-d2) - S*normCDF(-d1)
    result

// ── VOLATILITY ────────────────────────────────────────────────────
logRet   = math.log(close / close[1])
hv20     = ta.stdev(logRet, 20) * math.sqrt(252)
hv20_5ag = ta.stdev(logRet[5], 15) * math.sqrt(252)
baseIV   = math.max(hv20 * 1.7, 0.30)
ema10    = ta.ema(close, 10)

// ── TREND CONFIRMATION ────────────────────────────────────────────
// 1. EMA stack — 10/20/50 all aligned
ema20    = ta.ema(close, 20)
ema50    = ta.ema(close, 50)
emaStackBull = ema10 > ema20 and ema20 > ema50
emaStackBear = ema10 < ema20 and ema20 < ema50

// 2. ADX — trend strength (≥20 = directional, ≥25 = strong)
[diPlus, diMinus, adxVal] = ta.dmi(14, 14)
trendStrong = adxVal >= 20

// 3. RSI momentum
rsi14  = ta.rsi(close, 14)
rsiBull = rsi14 >= 50
rsiBear = rsi14 <= 50

// 4. Weekly trend (higher timeframe)
wClose  = request.security(syminfo.tickerid, "W", close)
wClose1 = request.security(syminfo.tickerid, "W", close[1])
weeklyBull = wClose > wClose1
weeklyBear = wClose < wClose1

// 5. Prior 2-day momentum (at least 2 of last 3 days in signal direction)
priorBull = (close[1]>close[2]?1:0)+(close[2]>close[3]?1:0)+(close[3]>close[4]?1:0) >= 2
priorBear = (close[1]<close[2]?1:0)+(close[2]<close[3]?1:0)+(close[3]<close[4]?1:0) >= 2

// ── TREND SCORE (0–5 points) ─────────────────────────────────────
// Each confirmed layer adds 1 point → score ≥ 3 = SURE TREND
trendScoreBull = (emaStackBull?1:0) + (trendStrong?1:0) + (rsiBull?1:0) + (weeklyBull?1:0) + (priorBull?1:0)
trendScoreBear = (emaStackBear?1:0) + (trendStrong?1:0) + (rsiBear?1:0) + (weeklyBear?1:0) + (priorBear?1:0)

i_trendMinScore = input.int(3, "Min Trend Score (0=off, 3=sure, 5=very sure)",
  minval=0, maxval=5, group="Risk (all modes)",
  tooltip="0=no filter | 2=moderate | 3=sure trend (recommended) | 4=strong | 5=all 5 layers must agree")

trendOK = i_trendMinScore <= 0 or
  (close >= open ? trendScoreBull >= i_trendMinScore
                 : trendScoreBear >= i_trendMinScore)

// ── EXPIRY DETECTION ──────────────────────────────────────────────
cutoverTs = timestamp("2024-10-28 00:00:00 +0530")
isExpiry  = time >= cutoverTs
  ? dayofweek == dayofweek.tuesday
  : dayofweek == dayofweek.friday

// ── HIGH-IMPACT EVENT CALENDAR ────────────────────────────────────
isHighImpact =
  (month==2 and dayofmonth==1  and year>=2017) or
  (year==2016 and month==2  and dayofmonth==29) or
  (year==2015 and month==2  and dayofmonth==28) or
  (year==2014 and month==7  and dayofmonth==10) or
  (year==2013 and month==2  and dayofmonth==28) or
  (year==2012 and month==3  and dayofmonth==16) or
  (year==2011 and month==2  and dayofmonth==28) or
  (year==2010 and month==2  and dayofmonth==26) or
  (year==2009 and month==2  and dayofmonth==16) or
  (year==2008 and month==2  and dayofmonth==29) or
  (year==2007 and month==2  and dayofmonth==28) or
  (year==2006 and month==2  and dayofmonth==28) or
  (year==2005 and month==2  and dayofmonth==28) or
  (year==2004 and month==5  and dayofmonth==13) or
  (year==2004 and month==5  and dayofmonth==14) or
  (year==2009 and month==5  and dayofmonth==16) or
  (year==2014 and month==5  and dayofmonth==16) or
  (year==2019 and month==5  and dayofmonth==23) or
  (year==2024 and month==6  and dayofmonth== 4) or
  (year==2019 and month==9  and dayofmonth==20) or
  (year==2020 and month==3  and dayofmonth==23) or
  (year==2016 and month==11 and dayofmonth== 8) or
  (year==2008 and month==10 and dayofmonth==24) or
  (year==2013 and month==8  and dayofmonth==16) or
  (year==2022 and month==5  and dayofmonth== 4) or
  (year==2022 and month==6  and dayofmonth== 8) or
  (year==2020 and month==3  and dayofmonth==27) or
  (year==2020 and month==5  and dayofmonth==22)

// ── SIGNAL LOGIC ─────────────────────────────────────────────────
rangePct  = (high - low) / open * 100
bodyPct   = math.abs(close - open) / open * 100
bodyRatio = rangePct > 0 ? bodyPct / rangePct : 0.0
gapPct    = (open - close[1]) / close[1] * 100
absGap    = math.abs(gapPct)
isBull    = close >= open

// Prior streak: count how many of last 3 days moved with signal direction
priorStreak = (isBull ? (close[1]>close[2]?1:0) + (close[2]>close[3]?1:0) + (close[3]>close[4]?1:0)
                      : (close[1]<close[2]?1:0) + (close[2]<close[3]?1:0) + (close[3]<close[4]?1:0))

// Filter gates
volOK    = hv20 >= (minHVpct / 100)
emaOK    = not useEMA or (isBull ? close >= ema10 : close <= ema10)
volExpOK = not useVolExp or (hv20 >= hv20_5ag * 0.90)
streakOK = streakMin <= 0 or priorStreak >= streakMin

// Gap alignment
gapAligned = (gapPct > 1.0 and isBull) or (gapPct < -1.0 and not isBull)

// Prior trend for gap reversal
prevTrendUp  = close[1] > close[3]
gapRevDown   = prevTrendUp  and gapPct < -1.2 and not isBull and bodyRatio >= 0.60
gapRevUp     = not prevTrendUp and gapPct > 1.2 and isBull   and bodyRatio >= 0.60

// Tier detection
isEventSig   = isHighImpact and bodyRatio >= 0.55 and rangePct >= 1.0
isPowerTrend = not isEventSig and bodyRatio >= powerBody and rangePct >= powerRange and absGap <= 3
isGapCont    = not isEventSig and not isPowerTrend and gapAligned and bodyRatio >= gapBody and rangePct >= gapRange
isTrendSig   = not isEventSig and not isPowerTrend and not isGapCont and bodyRatio >= 0.65 and rangePct >= 0.9 and absGap <= 5
isGapRevSig  = not isEventSig and not isPowerTrend and not isGapCont and not isTrendSig and (gapRevDown or gapRevUp) and rangePct >= 1.0

// Apply medium filter (drops TREND and GAP_REVERSAL when noMedium=true)
isHighConf   = isEventSig or isPowerTrend or isGapCont
isMedConf    = isTrendSig or isGapRevSig
hasRawSig    = isHighConf or (not noMedium and isMedConf)

// All filters combined (trendOK = sure market trend layer)
hasSignal    = isExpiry and volOK and emaOK and volExpOK and streakOK and hasRawSig and trendOK

// Strike offset
strikeOffset = isEventSig ? eventStk : (isPowerTrend or isGapCont) ? highStrike : 0
confTag      = isEventSig ? "EVENT⚡" : (isPowerTrend or isGapCont) ? "HIGH★" : "MED◆"
reasonTag    = isEventSig ? "HIGH_IMPACT" : isPowerTrend ? "POWER_TREND" : isGapCont ? "GAP_CONT" : isTrendSig ? "TREND" : "GAP_REV"

// Active filters display
filterStr = (useEMA ? "EMA " : "") + (useVolExp ? "VOLEXP " : "") + (streakMin > 0 ? "STREAK" + str.tostring(streakMin) + " " : "") + (noMedium ? "NO_MED" : "")

// ── OPTION PRICING ────────────────────────────────────────────────
r_rf     = 0.065
T_entry  = 6.0  / (252.0 * 6.5)
T_mid    = 3.0  / (252.0 * 6.5)

atm_s    = math.round(open / 100.0) * 100.0
strike   = isBull ? atm_s + strikeOffset * 100.0 : atm_s - strikeOffset * 100.0
iv_trade = baseIV * (1.0 + strikeOffset * 0.08)

entryOpt = bsPrice(open, strike, T_entry, r_rf, iv_trade, isBull)
validTrd = hasSignal and entryOpt >= 0.5

// ── SIGNAL-AWARE RISK PARAMS (matches JS backtest exactly) ───────
// HIGH (POWER_TREND, GAP_CONT): tighter SL + later trail trigger + higher lock
// EVENT/MEDIUM: standard SL + base trail values
isHighConf2   = isPowerTrend or isGapCont   // alias for clarity below
effectiveSLpct = isHighConf2 ? i_slPct * 0.85 : i_slPct
effTrailTrig   = isHighConf2 ? i_trail1x * 1.3 : i_trail1x
effTrailLock   = isHighConf2 ? math.min(i_trail1lk + 10.0, 70.0) : i_trail1lk

// ── DELTA-BASED STOP LOSS ─────────────────────────────────────────
sqrtT_e  = math.sqrt(T_entry)
d1_v     = (math.log(open / strike) + (r_rf + 0.5*iv_trade*iv_trade)*T_entry) / (iv_trade * sqrtT_e)
delta    = isBull ? normCDF(d1_v) : normCDF(-d1_v)
spotSLmv = entryOpt * (effectiveSLpct / 100.0) / math.max(delta, 0.05)
spotSL   = isBull ? open - spotSLmv : open + spotSLmv
slHit    = validTrd and (isBull ? low <= spotSL : high >= spotSL)

// ── TRAILING STOP (single level, signal-type-aware) ───────────────
spotBest   = isBull ? high : low
optBest    = bsPrice(spotBest, strike, T_mid, r_rf, iv_trade, isBull)

trailHit   = validTrd and optBest >= entryOpt * effTrailTrig
trailFloor = trailHit
  ? entryOpt + (optBest - entryOpt) * (effTrailLock / 100.0)
  : 0.0

// ── EXIT PRICE ────────────────────────────────────────────────────
slOptLevel = entryOpt * (1.0 - effectiveSLpct / 100.0)
intrinsicE = isBull ? math.max(close - strike, 0.05) : math.max(strike - close, 0.05)

exitOpt = slHit ? slOptLevel
  : trailFloor > 0 and intrinsicE < trailFloor ? trailFloor
  : intrinsicE

multiplier  = validTrd and entryOpt > 0.5 ? exitOpt / entryOpt : na
pnlPct      = not na(multiplier) ? (multiplier - 1.0) * 100.0 : na
isWin       = not na(pnlPct) and pnlPct > 0
exitReason  = slHit ? "SL" : (trailHit and exitOpt == trailFloor) ? "TRAIL" : "EOD"

// ── RUNNING STATS ─────────────────────────────────────────────────
var int   n_total = 0
var int   n_win   = 0
var float sumMult = 0.0
var float bestM   = 0.0
var float equityR = 0.0   // % return
var int   n_sl    = 0
var int   n_trail = 0
var int   n_event = 0
var int   n_high  = 0
var int   n_med   = 0
var int   n_3xp   = 0
var int   n_2xp   = 0

if validTrd and not na(multiplier)
    n_total += 1
    sumMult += multiplier
    equityR += (multiplier - 1.0) * 10.0   // 10% risk per trade, compound approx
    if isWin
        n_win += 1
    if multiplier > bestM
        bestM := multiplier
    if slHit
        n_sl += 1
    if exitReason == "TRAIL"
        n_trail += 1
    if isEventSig
        n_event += 1
    else if isPowerTrend or isGapCont
        n_high += 1
    else
        n_med += 1
    if multiplier >= 3
        n_3xp += 1
    if multiplier >= 2
        n_2xp += 1

// ── TRADE LABELS ─────────────────────────────────────────────────
if validTrd and not na(multiplier) and i_showLabel
    en_s = str.tostring(math.round(entryOpt * 10) / 10)
    ex_s = str.tostring(math.round(exitOpt  * 10) / 10)
    mu_s = str.tostring(math.round(multiplier * 100) / 100)
    sk_s = str.tostring(int(strike))
    pnl_s = (pnlPct >= 0 ? "+" : "") + str.tostring(math.round(pnlPct * 10) / 10)
    iv_s = str.tostring(math.round(iv_trade * 1000) / 10)

    multStar = multiplier >= 5 ? " ★★★" : multiplier >= 3 ? " ★★" : multiplier >= 2 ? " ★" : ""
    lbl_txt =
      (isBull ? "▲ CALL" : "▼ PUT") + "  [" + confTag + "]\n" +
      reasonTag + "\n" +
      "K=" + sk_s + "  IV=" + iv_s + "%\n" +
      "Entry ₹" + en_s + "  → Exit ₹" + ex_s + "  [" + exitReason + "]\n" +
      mu_s + "x   " + pnl_s + "%   " + (isWin ? "✓ WIN" : "✗ LOSS") + multStar

    multColor = multiplier >= 3 ? color.new(#00ff88, 0) : multiplier >= 2 ? color.new(color.lime, 0) : isWin ? color.new(color.green, 20) : color.new(color.red, 20)
    lbl_y = isBull ? low - (high - low) * 0.45 : high + (high - low) * 0.45

    label.new(bar_index, lbl_y, lbl_txt,
              style     = isBull ? label.style_label_up : label.style_label_down,
              color     = multColor,
              textcolor = color.white,
              size      = size.small)

// ── WEBHOOK ALERT CONDITIONS ──────────────────────────────────────
// In TradingView: Create Alert → Condition = one of these
// Webhook URL: http://YOUR_IP:3000/api/webhook/tradingview
// Message: (auto-filled below via alertcondition message)
alertcondition(validTrd and isBull and not na(multiplier),
  title   = "ANTIGRAVITY BUY CALL",
  message = '{"action":"BUY","signal":"CALL","strike":"' + str.tostring(int(strike)) + '","entry":"' + str.tostring(math.round(entryOpt*10)/10) + '","reason":"' + reasonTag + '","conf":"' + confTag + '","key":"antigravity"}')

alertcondition(validTrd and not isBull and not na(multiplier),
  title   = "ANTIGRAVITY BUY PUT",
  message = '{"action":"BUY","signal":"PUT","strike":"' + str.tostring(int(strike)) + '","entry":"' + str.tostring(math.round(entryOpt*10)/10) + '","reason":"' + reasonTag + '","conf":"' + confTag + '","key":"antigravity"}')

alertcondition(isExpiry and not hasSignal,
  title   = "ANTIGRAVITY NO SIGNAL",
  message = '{"action":"WAIT","signal":"NONE","key":"antigravity"}')

// ── SIGNAL SHAPES ────────────────────────────────────────────────
plotshape(validTrd and  isBull and not na(multiplier), title="CALL",
          style=shape.triangleup,   location=location.belowbar,
          color=color.new(color.lime, 0), size=size.small)
plotshape(validTrd and not isBull and not na(multiplier), title="PUT",
          style=shape.triangledown, location=location.abovebar,
          color=color.new(color.red, 0),  size=size.small)

// ── BACKGROUND HIGHLIGHT ─────────────────────────────────────────
bgcolor(isExpiry and not hasSignal ? color.new(color.gray, 95) : na)
bgcolor(validTrd and  isBull ? color.new(color.green, 92) : na)
bgcolor(validTrd and not isBull ? color.new(color.red, 92) : na)

// ── EMA PLOT ──────────────────────────────────────────────────────
plot(i_showEMA ? ema10 : na, "EMA 10", color=color.new(color.orange, 0), linewidth=1)

// ── OPTION CHAIN TABLE ────────────────────────────────────────────
if i_showChain and barstate.islast and isExpiry
    var table ct = table.new(position.bottom_left, 7, 9,
                   border_width=1, border_color=color.new(color.gray,60),
                   bgcolor=color.new(#0d1117, 15))
    hBg = color.new(color.navy, 20)
    table.cell(ct,0,0,"Strike",   text_color=color.yellow, bgcolor=hBg, text_size=size.small)
    table.cell(ct,1,0,"CE Prem",  text_color=color.yellow, bgcolor=hBg, text_size=size.small)
    table.cell(ct,2,0,"PE Prem",  text_color=color.yellow, bgcolor=hBg, text_size=size.small)
    table.cell(ct,3,0,"CE Mult",  text_color=color.yellow, bgcolor=hBg, text_size=size.small)
    table.cell(ct,4,0,"PE Mult",  text_color=color.yellow, bgcolor=hBg, text_size=size.small)
    table.cell(ct,5,0,"CE Delta", text_color=color.yellow, bgcolor=hBg, text_size=size.small)
    table.cell(ct,6,0,"Tag",      text_color=color.yellow, bgcolor=hBg, text_size=size.small)

    T_now = 6.0 / (252.0 * 6.5)
    atm_n = math.round(open / 100.0) * 100.0
    for i = 0 to 6
        off = i - 3
        k   = atm_n + off * 100.0
        ivk = baseIV * (1.0 + math.abs(off) * 0.08)
        ceP = bsPrice(open, k, T_now, r_rf, ivk, true)
        peP = bsPrice(open, k, T_now, r_rf, ivk, false)
        ceI = math.max(close - k, 0.05)
        peI = math.max(k - close, 0.05)
        ceM = ceP > 0.5 ? str.tostring(math.round(ceI/ceP*100)/100) + "x" : "—"
        peM = peP > 0.5 ? str.tostring(math.round(peI/peP*100)/100) + "x" : "—"
        // Delta of CE
        sqT_c  = math.sqrt(T_now)
        d1_c   = (math.log(open/k) + (r_rf + 0.5*ivk*ivk)*T_now) / (ivk * sqT_c)
        ceD    = str.tostring(math.round(normCDF(d1_c) * 100)) + "%"
        tag    = k == atm_n ? "←ATM" : (validTrd and k == strike) ? "←SIGNAL" : ""
        rBg    = k == strike and validTrd ? color.new(color.yellow,75) : k == atm_n ? color.new(color.blue,80) : color.new(#0d1117,35)

        table.cell(ct, 0, i+1, str.tostring(int(k)),                       bgcolor=rBg, text_color=color.white,  text_size=size.small)
        table.cell(ct, 1, i+1, "₹" + str.tostring(math.round(ceP*10)/10), bgcolor=rBg, text_color=color.teal,   text_size=size.small)
        table.cell(ct, 2, i+1, "₹" + str.tostring(math.round(peP*10)/10), bgcolor=rBg, text_color=color.orange, text_size=size.small)
        table.cell(ct, 3, i+1, ceM,  bgcolor=rBg, text_color=color.teal,   text_size=size.small)
        table.cell(ct, 4, i+1, peM,  bgcolor=rBg, text_color=color.orange, text_size=size.small)
        table.cell(ct, 5, i+1, ceD,  bgcolor=rBg, text_color=color.gray,   text_size=size.small)
        table.cell(ct, 6, i+1, tag,  bgcolor=rBg, text_color=color.yellow, text_size=size.small)

// ── STATS TABLE ───────────────────────────────────────────────────
if i_showStats and barstate.islast
    var table st = table.new(position.top_right, 2, 17,
                   border_width=1, border_color=color.new(color.gray,50),
                   bgcolor=color.new(#0d1117, 15))

    winRate = n_total > 0 ? math.round(n_win / n_total * 1000) / 10 : 0.0
    avgMult = n_total > 0 ? math.round(sumMult / n_total * 1000) / 1000 : 0.0

    hBg  = color.new(color.navy, 10)
    cBg  = color.new(#0d1117, 35)
    hTxt = color.yellow
    vTxt = color.white

    table.cell(st, 0, 0, "v2 " + i_mode,    text_color=hTxt, bgcolor=hBg, text_size=size.small)
    table.cell(st, 1, 0, "SENSEX OPTIONS",   text_color=hTxt, bgcolor=hBg, text_size=size.small)

    table.cell(st, 0, 1, "Trades",           text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 1, str.tostring(n_total), text_color=vTxt, bgcolor=cBg, text_size=size.small)

    winColor = winRate >= 65 ? color.new(#00ff88,0) : winRate >= 55 ? color.lime : color.orange
    table.cell(st, 0, 2, "Win Rate",          text_color=hTxt,    bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 2, str.tostring(winRate) + "%", text_color=winColor, bgcolor=cBg, text_size=size.small)

    multColor2 = avgMult >= 1.4 ? color.new(#00ff88,0) : avgMult >= 1.2 ? color.lime : color.orange
    table.cell(st, 0, 3, "Avg Multiplier",    text_color=hTxt,       bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 3, str.tostring(avgMult) + "x", text_color=multColor2, bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 4, "Best Trade",        text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 4, str.tostring(math.round(bestM*100)/100) + "x", text_color=color.new(#00ff88,0), bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 5, "3X+ trades",        text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 5, str.tostring(n_3xp), text_color=color.new(#00ff88,0), bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 6, "2X+ trades",        text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 6, str.tostring(n_2xp), text_color=color.lime, bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 7, "Stop Losses",       text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 7, str.tostring(n_sl),  text_color=color.orange, bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 8, "Trail Exits",       text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 8, str.tostring(n_trail), text_color=color.teal, bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 9,  "── By Signal ──",  text_color=color.gray, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 9,  "",                 bgcolor=cBg)
    table.cell(st, 0, 10, "EVENT ⚡",          text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 10, str.tostring(n_event), text_color=color.yellow, bgcolor=cBg, text_size=size.small)
    table.cell(st, 0, 11, "HIGH ★",            text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 11, str.tostring(n_high), text_color=color.lime, bgcolor=cBg, text_size=size.small)
    table.cell(st, 0, 12, "MEDIUM ◆",          text_color=hTxt, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 12, str.tostring(n_med),  text_color=color.orange, bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 13, "── Equity ──",      text_color=color.gray, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 13, "",                  bgcolor=cBg)
    eqCol = equityR >= 0 ? color.lime : color.red
    eqStr = (equityR >= 0 ? "+" : "") + str.tostring(math.round(equityR * 10) / 10) + "%"
    table.cell(st, 0, 14, "Equity Return",     text_color=hTxt,  bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 14, eqStr,               text_color=eqCol, bgcolor=cBg, text_size=size.small)

    table.cell(st, 0, 15, "── Filters ──",     text_color=color.gray, bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 15, "",                  bgcolor=cBg)
    table.cell(st, 0, 16, "Active",            text_color=hTxt,       bgcolor=cBg, text_size=size.small)
    table.cell(st, 1, 16, filterStr == "" ? "NONE" : filterStr, text_color=color.teal, bgcolor=cBg, text_size=size.small)

// ── TODAY INFO (bar label on current expiry) ─────────────────────
if isExpiry and barstate.islast
    hv_s  = str.tostring(math.round(hv20 * 1000) / 10)
    iv_s  = str.tostring(math.round(baseIV * 1000) / 10)
    sig_s = hasSignal
      ? "  SIGNAL: " + (isBull ? "CALL" : "PUT") + " [" + confTag + "]  K=" + str.tostring(int(strike)) + "  Entry≈₹" + str.tostring(math.round(entryOpt * 10) / 10)
      : (not volOK ? "  NO SIGNAL — low vol (" + hv_s + "%<" + str.tostring(minHVpct) + "%)"
         : not emaOK ? "  NO SIGNAL — EMA filter blocked"
         : not volExpOK ? "  NO SIGNAL — vol contracting"
         : not hasRawSig ? "  No pattern (body/range not met)"
         : not trendOK ? "  NO SIGNAL — trend score " + str.tostring(isBull ? trendScoreBull : trendScoreBear) + "/5 < " + str.tostring(i_trendMinScore) + " (need sure trend)"
         : "  Filters blocked — check CUSTOM inputs")

    label.new(bar_index, high + (high-low)*0.15,
              "EXPIRY  HV=" + hv_s + "%  IV=" + iv_s + "%" + sig_s,
              style=label.style_label_down,
              color=hasSignal ? color.new(color.navy, 10) : color.new(color.gray, 30),
              textcolor=color.yellow, size=size.normal)

// ── BUY / SELL SINGLE SIGNAL PANEL ───────────────────────────────
// Large prominent panel: shows TODAY's trade or WAIT clearly
if barstate.islast
    var table sig = table.new(position.top_left, 2, 8,
                   border_width=2, border_color=color.new(color.gray, 40),
                   bgcolor=color.new(#0d1117, 5))

    // Header row
    hdrBg  = isExpiry ? (hasSignal ? (isBull ? color.new(#003300,0) : color.new(#330000,0)) : color.new(#1a1a1a,0)) : color.new(#0d1117,0)
    hdrTxt = isExpiry and hasSignal ? color.white : color.new(color.gray, 30)
    table.cell(sig, 0, 0, "TODAY", text_color=hdrTxt, bgcolor=hdrBg, text_size=size.normal)
    table.cell(sig, 1, 0, isExpiry ? "EXPIRY DAY" : "NOT EXPIRY", text_color=hdrTxt, bgcolor=hdrBg, text_size=size.normal)

    // Main BUY / SELL / WAIT signal
    if isExpiry and hasSignal
        dirBg   = isBull ? color.new(#00aa00, 0) : color.new(#cc0000, 0)
        dirTxt  = isBull ? "▲  BUY  CALL" : "▼  SELL  PUT"
        table.cell(sig, 0, 1, dirTxt,  text_color=color.white, bgcolor=dirBg, text_size=size.large)
        table.cell(sig, 1, 1, confTag, text_color=color.yellow, bgcolor=dirBg, text_size=size.large)
    else
        waitTxt = isExpiry ? "◼  WAIT  ◼" : "◼  NO TRADE ◼"
        table.cell(sig, 0, 1, waitTxt, text_color=color.new(color.gray,20), bgcolor=color.new(#111111,0), text_size=size.large)
        table.cell(sig, 1, 1, isExpiry ? (not hasRawSig ? "no pattern" : "filtered") : "—",
                   text_color=color.new(color.gray,40), bgcolor=color.new(#111111,0), text_size=size.normal)

    cBg2 = color.new(#0d1117, 30)
    lTxt = color.new(color.gray, 20)
    vClr = isExpiry and hasSignal ? color.white : color.new(color.gray, 40)

    // Strike
    skStr = isExpiry and hasSignal ? str.tostring(int(strike)) + (isBull ? " CE" : " PE") : "—"
    table.cell(sig, 0, 2, "Strike",  text_color=lTxt, bgcolor=cBg2, text_size=size.small)
    table.cell(sig, 1, 2, skStr,     text_color=vClr, bgcolor=cBg2, text_size=size.small)

    // Entry premium
    epStr = isExpiry and hasSignal ? "₹" + str.tostring(math.round(entryOpt * 10) / 10) : "—"
    table.cell(sig, 0, 3, "Entry Prem", text_color=lTxt, bgcolor=cBg2, text_size=size.small)
    table.cell(sig, 1, 3, epStr,        text_color=vClr, bgcolor=cBg2, text_size=size.small)

    // Stop loss level (option price)
    slStr = isExpiry and hasSignal
      ? "₹" + str.tostring(math.round(entryOpt * (1.0 - effectiveSLpct/100.0) * 10) / 10) + "  (" + str.tostring(math.round(effectiveSLpct*10)/10) + "%)"
      : "—"
    table.cell(sig, 0, 4, "Stop Loss",  text_color=lTxt,               bgcolor=cBg2, text_size=size.small)
    table.cell(sig, 1, 4, slStr,        text_color=color.new(color.orange,0), bgcolor=cBg2, text_size=size.small)

    // Target 2x
    t2Str = isExpiry and hasSignal ? "₹" + str.tostring(math.round(entryOpt * 2.0 * 10) / 10) + "  (+100%)" : "—"
    table.cell(sig, 0, 5, "Target 2×",  text_color=lTxt,              bgcolor=cBg2, text_size=size.small)
    table.cell(sig, 1, 5, t2Str,        text_color=color.new(color.lime,0), bgcolor=cBg2, text_size=size.small)

    // Target 3x
    t3Str = isExpiry and hasSignal ? "₹" + str.tostring(math.round(entryOpt * 3.0 * 10) / 10) + "  (+200%)" : "—"
    table.cell(sig, 0, 6, "Target 3×",  text_color=lTxt,                     bgcolor=cBg2, text_size=size.small)
    table.cell(sig, 1, 6, t3Str,        text_color=color.new(#00ff88,0), bgcolor=cBg2, text_size=size.small)

    // Trend score bar
    tScore    = isBull ? trendScoreBull : trendScoreBear
    tScoreStr = str.tostring(tScore) + "/5  " +
      (emaStackBull or emaStackBear ? "EMA✓ " : "EMA✗ ") +
      (trendStrong ? "ADX✓ " : "ADX✗ ") +
      (isBull ? (rsiBull ? "RSI✓ " : "RSI✗ ") : (rsiBear ? "RSI✓ " : "RSI✗ ")) +
      (isBull ? (weeklyBull ? "W✓" : "W✗") : (weeklyBear ? "W✓" : "W✗"))
    tScoreColor = tScore >= 4 ? color.new(#00ff88,0) : tScore >= 3 ? color.lime : color.orange
    table.cell(sig, 0, 7, "Trend Score", text_color=lTxt, bgcolor=cBg2, text_size=size.small)
    table.cell(sig, 1, 7, tScoreStr, text_color=tScoreColor, bgcolor=cBg2, text_size=size.small)

    // Trail info row
    trailStr = isExpiry and hasSignal
      ? "trail@" + str.tostring(math.round(effTrailTrig*10)/10) + "x  lock" + str.tostring(int(effTrailLock)) + "%"
      : "—"
    table.cell(sig, 0, 8 if false else 0, "", bgcolor=cBg2, text_size=size.tiny)  // spacer (unused — table is 8 rows)
    // Overwrite row 7 label to show reason + trail on same row handled above
