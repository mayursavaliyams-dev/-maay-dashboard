# ============================================================
# Antigravity Bot — Configuration
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Dhan API (live + backtest) ------------------------------
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
# Optional: override base URL (default https://api.dhan.co)
DHAN_BASE_URL=https://api.dhan.co

# --- Risk management (used by live trader AND real backtest) -
MAX_TRADES_PER_DAY=2
CAPITAL_PER_TRADE_PERCENT=5
# Stop-loss: exit when option premium drops this % below entry
STOP_LOSS_PERCENT=35
# Target: book full profit when option premium hits this % above entry
# 400% = 5x premium (Friday 5× target preset)
TARGET_PERCENT=400
# Trailing stop: after price reaches this multiple, lock in profit
TRAIL_AFTER_MULTIPLE=2
# Lock this % of peak gain once trailing is active
TRAIL_LOCK_PERCENT=50

# --- Real backtest (Dhan historical option data) -------------
# How many past expiry days to test (max ~260 = 5y)
BACKTEST_NUM_EXPIRIES=200
# Candle interval in minutes: 1, 5, 15, 25, 60
BACKTEST_INTERVAL=5
# Strike offset from ATM: 0=ATM, 1=OTM1, 2=OTM2...
BACKTEST_STRIKE_OFFSET=1
# Cutover date when BSE SENSEX weekly expiry moved Fri→Tue
# (approx when SEBI's expiry rationalization took effect)
SENSEX_EXPIRY_CUTOVER=2024-10-28
# Force Friday-only expiries for the entire backtest history,
# overriding the post-cutover Tuesday switch above.
BACKTEST_FRIDAY_ONLY=true
# Cache dir for Dhan responses (skip re-fetches on rerun)
BACKTEST_CACHE_DIR=./data/dhan-cache

# --- Server --------------------------------------------------
PORT=3000
NODE_ENV=development
# Optional: when the dashboard is hosted separately, point it at the live API
PUBLIC_API_BASE_URL=

# --- Telegram Alerts (real-time push to your phone) ----------
# SETUP (30 seconds):
#   1. Open Telegram → search @BotFather → /newbot
#   2. Name: "Antigravity Bot" → Username: "your_antigravity_bot"
#   3. Copy the token → paste below
#   4. Start your bot (open it in Telegram, press START)
#   5. Send it any message, then visit:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      Copy the chat.id number → paste below
#   6. Set TELEGRAM_ENABLED=true
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Alerts sent: Signals, Gamma Blasts, Position SL/Trail/Target,
#              Expiry morning briefing, Daily summary
# Bot commands: /status /blast /position /chain /help

# --- Browser Alerts ------------------------------------------
ALERT_SOUND=true
ALERT_POPUP=true
